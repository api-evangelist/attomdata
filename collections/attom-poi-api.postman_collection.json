  "info": {
    "_postman_id": "220481c1-6d13-4bd8-876a-9868932742a3",
    "name": "ATTOM POI API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "ATTOM Points of Interest (POI) API returns businesses and points of interest\nby point (lat/lon + radius) or by address. Supports 120+ business categories\nincluding restaurants, banks, retail, services, and recreation, with optional\nfilters by line of business, industry, and category name.\n\n\nContact Support:\n Name: ATTOM Data Customer Care\n Email: datacustomercare@attomdata.com",
      "type": "text/plain"
    }
  }
