    {
      "id": "f54ad85a-6007-42ce-863f-8e3e2d983a4f",
      "name": "POI Search",
      "description": {
        "content": "Search points of interest by point or address.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "b16bf19c-57b3-49bb-8e72-5a077f00dbd0",
          "name": "Search POIs",
          "request": {
            "name": "Search POIs",
            "description": {
              "content": "Search points of interest. Provide either `point` (lat/lon) **or** `address`\nplus a `radius`. Optional filters narrow results to categories, lines of business,\nor specific industries.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "v4",
                "neighborhood",
                "poi"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "point",
                  "value": "<string>",
                  "description": "Latitude,longitude pair (e.g., \"39.7710,-104.9636\")."
                },
                {
                  "disabled": false,
                  "key": "address",
                  "value": "<string>",
                  "description": "Postal address; combine with `radius` to search around it."
                },
                {
                  "disabled": false,
                  "key": "radius",
                  "value": "<float>",
                  "description": "(Required) Search radius in miles."
                },
                {
                  "disabled": false,
                  "key": "category",
                  "value": "<string>",
                  "description": "Comma-separated category names."
                },
                {
                  "disabled": false,
                  "key": "lineofbusiness",
                  "value": "<string>",
                  "description": "Comma-separated line-of-business codes."
                },
                {
                  "disabled": false,
                  "key": "industry",
                  "value": "<string>",
                  "description": "Comma-separated industry codes."
                }
              ],
              "variable": []
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
